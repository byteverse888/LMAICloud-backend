# App Configuration
APP_NAME=LMAICloud
APP_ENV=development
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lmaicloud

# Redis Configuration (for ARQ task queue)
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Storage Configuration
STORAGE_ROOT=/opt/data

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# K8s Cluster Configuration
K8S_CLUSTER_NAME=default-cluster
K8S_CLUSTER_REGION=cn-beijing
KUBECONFIG_PATH=  # 留空则使用默认路径 ~/.kube/config
DEFAULT_GPU_HOURLY_PRICE=5.0

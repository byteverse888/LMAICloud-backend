# ============ App Configuration ============
APP_NAME=LMAICloud
APP_ENV=development
DEBUG=True
FRONTEND_URL=http://localhost:3000

# ============ Database ============
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lmaicloud

# ============ Redis (ARQ task queue) ============
REDIS_URL=redis://localhost:6379/0

# ============ JWT ============
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============ CORS ============
CORS_ORIGINS=http://localhost:3000

# ============ Storage ============
STORAGE_ROOT=/opt/data
STORAGE_BACKEND=ipfs
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080
USER_STORAGE_DEFAULT_QUOTA_GB=10
USER_UPLOAD_MAX_SIZE_MB=50
USER_MAX_FILE_COUNT=100

# ============ Logging ============
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# ============ K8s Cluster ============
K8S_CLUSTER_NAME=default-cluster
K8S_CLUSTER_REGION=cn-beijing
KUBECONFIG_PATH=  # 留空则使用默认路径 ~/.kube/config
DEFAULT_GPU_HOURLY_PRICE=5.0

# ============ Email SMTP ============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@lmaicloud.com
SMTP_FROM_NAME=LMAICloud
SMTP_USE_TLS=true
EMAIL_ACTIVATION_EXPIRE_HOURS=24

# ============ WeChat Pay (V2) ============
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=
WECHAT_TEST_MODE=true  # true=模拟支付, false=真实微信支付

# ============ OpenClaw ============
OPENCLAW_DEFAULT_PORT=18789
OPENCLAW_DEFAULT_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_STORAGE_CLASS=standard
OPENCLAW_EDGE_STORAGE_PATH=/opt/openclaw-data
